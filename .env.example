# Copy to .env and fill in values.

FEATHERLESS_AI_API_KEY=

# --- IBM Db2 session persistence (optional) ---
# Full CLI connection string, e.g. DATABASE=BLUDB;HOSTNAME=db2-xxxxx.databases.appdomain.cloud;
# PORT=50001;PROTOCOL=TCPIP;UID=db2inst1;PWD=...;SECURITY=SSL
# IBM_DB_CONN_STRING=
# Optional per-user key for scoping last-10 sessions (omit for single-user).
# SENSUS_USER_ID=
# Set to 1 to auto-CREATE TABLE on first connect (dev only). If you see SQL0204 / undefined
# MESSAGES or SESSIONS, run scripts/db2_schema.sql in the Db2 console or enable this.
# IBM_DB_AUTO_SCHEMA=0

# DeepSeek one-line session summary on overlay close (OpenAI-compatible API).
# Model deepseek-chat is DeepSeek-V3 on api.deepseek.com.
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_SUMMARY_MODEL=deepseek-chat
# DEEPSEEK_SUMMARY_TIMEOUT_SEC=45

# Orchestrator (main.py), router (classify_intent), and browser action planner.
FEATHERLESS_ORCHESTRATOR_MODEL=google/gemma-4-31B-it

# Vision / multimodal (sensus/vision/screen.py — desktop + browser screenshots).
FEATHERLESS_VISION_MODEL=google/gemma-3-12b-it
# If the primary model is gated (403), try an ungated multimodal model on Featherless:
# FEATHERLESS_VISION_MODEL_FALLBACK=...
# Or several: FEATHERLESS_VISION_MODEL_FALLBACKS=model/a,model/b

# Browser (sensus/agents/browser.py): Firefox fullscreen by default; windowed 1920x1080 if off.
# SENSUS_BROWSER_FULLSCREEN=0
# SENSUS_BROWSER_WINDOW_WIDTH=1920
# SENSUS_BROWSER_WINDOW_HEIGHT=1080
# Where Playwright saves files when a planned step uses expect_download (default ~/Downloads).
# SENSUS_BROWSER_DOWNLOAD_DIR=/home/you/Downloads
# Max milliseconds to wait for a download after click/navigate (default 120000).
# SENSUS_BROWSER_DOWNLOAD_TIMEOUT_MS=120000

# Optional
# FEATHERLESS_BASE_URL=https://api.featherless.ai/v1
# FEATHERLESS_ORCHESTRATOR_TIMEOUT_SEC=120
# FEATHERLESS_ROUTER_TIMEOUT_SEC=30

# Shortcuts (sensus/agents/shortcuts.py) — Ubuntu: pactl, brightnessctl, playerctl,
# gtk-launch + .desktop index, MPRIS OpenUri spotify:search:… (no Spotify Web API).
# TTS (voice/tts.py): WebSocket chunks are coalesced before PyAudio to avoid underrun/static.
# SENSUS_TTS_PREBUFFER_MS=400
# SENSUS_TTS_MIN_WRITE_MS=80
# SENSUS_TTS_FRAMES_PER_BUFFER=4096
# SENSUS_TTS_LEADING_SILENCE_MS=90
# SENSUS_SHORTCUTS_VISION_STEPS=4
# SENSUS_SPOTIFY_SEARCH_WAIT=1.2
# SENSUS_SPOTIFY_SEARCH_KEYS=Return

# Overlay window (GTK): keep above other windows and snap to a corner.
# SENSUS_OVERLAY_PIN=1
# top-right (default) or top-left
# SENSUS_OVERLAY_CORNER=top-right

# IBM Speech (see voice docs)
# IBM_STT_API_KEY=
# IBM_STT_URL=
# IBM_TTS_API_KEY=
# IBM_TTS_URL=
